MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/pingup
JWT_SECRET=your_secure_jwt_secret_change_this
PORT=3001

# Seed script passwords (only needed if running seed.js locally)
SEED_ADMIN_PASSWORD=choose_your_own_password
SEED_MOD_PASSWORD=choose_your_own_password
SEED_MEMBER_PASSWORD=choose_your_own_password
REFRESH_SECRET=super_secret_refresh_key
ALLOWED_ORIGINS=http://localhost:5173,https://mycustomdomain.com
REFRESH_SECRET=your_secure_refresh_token_secret_change_this
